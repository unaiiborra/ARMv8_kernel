CROSS_COMPILE      = aarch64-none-elf-
CROSS_COMPILE_PATH = /usr/lib/gcc/aarch64-none-elf/15.2.1

## Rust is now just used for the uart drivers, althought it is planned
## to be used in some other higher level parts of the kernel
RS_TARGET = aarch64-unknown-none


## Build profile: (release | gdb)
## release: -O2, no debug symbols (default)
## gdb: -O0 -g3, defines -DDEBUG=1 unless overridden with DEBUG = 0 | 2
CONFIG = release

## --- Per variable overrides ---
## These override the individual settings implied by CONFIG

## DEBUG: defines -DDEBUG (LV) (runtime checks and logs). Does not affect OPT_LEVEL nor gdb symbols
## Has 3 levels
## 0 = NONE: Not defined
## 1 = LOG: Runtime checks and basic logs
## 2 = TRACE: Runtime checks and detailed logs (for example each syscall)
# DEBUG = 0

## OPT_LEVEL: overrides the optimization flags from CONFIG
# OPT_LEVEL = -O2

## MCPU: target CPU. Affects -mcpu= passed to gcc.
# MCPU = cortex-a53+simd

